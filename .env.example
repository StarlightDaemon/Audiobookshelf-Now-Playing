# Audiobookshelf Now Playing — environment variables
# Copy to /etc/audiobookshelf-now-playing.env on the LXC and fill in values.

# Internal URL of your Audiobookshelf instance (no trailing slash)
ABS_HOST=http://192.168.1.100:13378

# API token from ABS → Settings → Users → (your user) → API Token
ABS_TOKEN=your-abs-api-token-here

# How often (seconds) to poll ABS for the current session.
# Shorter = detects new books faster. Recommended: 10–30.
SESSION_TTL=10

# How long (seconds) to cache cover art and metadata per book.
# Only re-fetched when you switch books or this expires.
CARD_TTL=300

# Bind address and port for uvicorn
HOST=0.0.0.0
PORT=8000
