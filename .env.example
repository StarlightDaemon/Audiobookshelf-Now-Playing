# Audiobookshelf Now Playing — environment variables
# Copy to /etc/audiobookshelf-now-playing.env on the LXC and fill in values.

# Internal URL of your Audiobookshelf instance (no trailing slash)
ABS_HOST=http://192.168.1.100:13378

# API token from ABS → Settings → Users → (your user) → API Token
ABS_TOKEN=your-abs-api-token-here

# How often (seconds) to poll ABS for the current session.
# Shorter = detects new books faster. Recommended: 10–30.
SESSION_TTL=10

# How long (seconds) to cache cover art and metadata per book.
# Only re-fetched when you switch books or this expires.
CARD_TTL=300

# How old (seconds) the most recent listening session may be before it's
# considered stale and no longer shown as "currently reading" — prevents a
# book finished long ago from lingering on the card. Set to 0 to disable.
# Session age is measured against this host's clock, so it assumes this host
# and the ABS server keep reasonably synced clocks (NTP).
SESSION_MAX_AGE=3600

# Bind address and port for uvicorn
HOST=0.0.0.0
PORT=8000

# Optional: path where runtime config (layout, theme, label, corners) is read
# and written. Defaults to /opt/audiobookshelf-now-playing/config.json.
# The systemd unit's ReadWritePaths covers /opt/audiobookshelf-now-playing/.
#CONFIG_PATH=/opt/audiobookshelf-now-playing/config.json

# Optional: path to the resolved Fujin token JSON file used for settings UI
# theming. When unset the application falls back to built-in defaults.
#FUJIN_TOKENS=/opt/audiobookshelf-now-playing/fujin-tokens-resolved.json

# Cloudflare Access gating for /settings and /api/config.
# When BOTH are set, the app verifies the Cf-Access-Jwt-Assertion header that
# Cloudflare Access injects — validating the JWT's signature (against your team's
# published signing keys), audience, issuer, and expiry — and rejects requests
# with a missing (401) or invalid (403) token. /card and /health stay public.
# When either is unset, enforcement is OFF (a startup warning is logged) so
# local/dev use keeps working. See the README "Cloudflare Access" section.
#
# Your Access team domain. A bare name, a *.cloudflareaccess.com host, or a
# full https:// URL are all accepted.
#CF_ACCESS_TEAM_DOMAIN=myteam.cloudflareaccess.com
#
# The Application Audience (AUD) tag of the Access application covering
# /settings and /api/* — copy it from the Access application's Overview page.
#CF_ACCESS_AUD=your-access-application-aud-tag
